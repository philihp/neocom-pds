# Supabase project URL and anon key (from Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Turnstile site key (from Cloudflare Dashboard → Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-site-key

# URL of the PDS backend (the Express/ATProto server)
PDS_API_URL=http://localhost:2583
