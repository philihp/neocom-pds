# ---- PDS core ----
PDS_HOSTNAME=pds.philihp.com

# I use "pds.edencom.link" as my PDS_HOSTNAME, to get around Railway considering that
# *.edencom.link does not also include edencom.link, which is fair I guess but I dont
# really appreciate it, so the DNS for edencom.link actually goes to my entryway app.
PDS_SERVICE_HANDLE_DOMAINS=.localhost.dev

# PDS_PORT is intentionally omitted for Railway — Railway injects $PORT automatically.
# Only set PDS_PORT for local development (e.g. PDS_PORT=2583).
PDS_DATA_DIRECTORY=./data
PDS_BLOBSTORE_DISK_LOCATION=./data/blocks
PDS_BLOB_UPLOAD_LIMIT=52428800

# Generate with: openssl rand --hex 16
PDS_JWT_SECRET=REPLACE_ME
PDS_ADMIN_PASSWORD=REPLACE_ME
# Generate with: openssl rand --hex 16 (this is a secp256k1 private key hex)
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX=REPLACE_ME

PDS_DID_PLC_URL=https://plc.directory
PDS_BSKY_APP_VIEW_URL=https://api.bsky.app
PDS_BSKY_APP_VIEW_DID=did:web:api.bsky.app
PDS_REPORT_SERVICE_URL=https://mod.bsky.app
PDS_REPORT_SERVICE_DID=did:plc:ar7c4by46qjdydhdevvrndac
PDS_CRAWLERS=https://bsky.network

# Disable invite codes (EVE SSO is our gate)
PDS_INVITE_REQUIRED=false

# Set to true for local development (skips https-scheme enforcement)
# PDS_DEV_MODE=true

# ---- EVE SSO ----
EVE_CLIENT_ID=REPLACE_ME
EVE_CLIENT_SECRET=REPLACE_ME
# Must exactly match the callback URL registered at developers.eveonline.com
EVE_CALLBACK_URL=https://pds.philihp.com/eve/callback
# Space-separated. Use "publicData" for minimum needed for identity.
# To fetch live character data (ship, location, etc), add the relevant ESI
# scopes here; users will need to re-auth to grant them.
EVE_SCOPES=publicData
# Contact email included in ESI User-Agent. CCP uses this to reach you if
# your app misbehaves. REQUIRED - not optional.
EVE_CONTACT_EMAIL=REPLACE_ME

# Generate with: openssl rand -base64 32
# Rotating this invalidates every stored refresh token (users must re-auth).
EVE_TOKEN_ENCRYPTION_KEY=REPLACE_ME

# ---- Web app / Supabase ----
# Your Supabase project URL (Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
# Publishable/anon key (sb_publishable_…) — used for password validation
SUPABASE_ANON_KEY=REPLACE_ME
# Secret key (sb_secret_…) from Project Settings → API Keys
SUPABASE_SECRET_KEY=REPLACE_ME
# URL of the web frontend (Next.js app), used to redirect after EVE binding
WEB_APP_URL=https://app.example.com
