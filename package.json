{
  "name": "eve-pds",
  "version": "0.1.0",
  "description": "ATProto PDS gated by EVE Online SSO",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @edencom/character-slug build && tsc",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "purge-anon-users": "tsx src/scripts/purge-anon-users.ts"
  },
  "dependencies": {
    "@edencom/character-slug": "workspace:*",
    "@atproto/api": "^0.13.0",
    "@atproto/pds": "^0.4.217",
    "@supabase/supabase-js": "^2.104.1",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jose": "^5.9.0",
    "ramda": "^0.30.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/ramda": "^0.30.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}